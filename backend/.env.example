# ============================================
# Smart Doc Platform - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#
# 注意: .env 文件不会被 Git 追踪 (已在 .gitignore 中排除)
# ============================================

# --- AI 模型配置 ---
# 默认 AI 提供商: kimi | deepseek | arkclaw
DEFAULT_MODEL_PROVIDER=kimi

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# Kimi (https://platform.moonshot.cn)
KIMI_API_KEY=sk-3V55tq2xwso8dhE4vFI5X9MssR6Y0Uw1BCkIUnGAP9f5dMo8
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# ArkClaw 审核引擎 (可选)
ARKCLAW_API_KEY=
ARKCLAW_BASE_URL=https://api.arkclaw.com/v1
ARKCLAW_MODEL=arkclaw-chat

# --- 数据库 (一般不需要修改) ---
# DATABASE_URL=sqlite:///./app.db
