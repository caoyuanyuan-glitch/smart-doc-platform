# ============================================
# Smart Doc Platform - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值，或放到机器级固定位置:
#   Windows: C:\Users\<你的用户名>\.smart-doc-platform\runtime.env
#   Linux/macOS: ~/.smart-doc-platform/runtime.env
#   自定义路径: 设置 SMART_DOC_ENV_FILE 指向你的 runtime.env
#
# 注意: .env/runtime.env 文件不会被 Git 追踪；推荐服务器使用用户目录下的固定 runtime.env，更新代码时不会丢失
# ============================================

# --- AI 模型配置 ---
# 默认 AI 提供商: kimi | deepseek | arkclaw
DEFAULT_MODEL_PROVIDER=kimi

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# Kimi (https://platform.moonshot.cn)
KIMI_API_KEY=sk-your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# 可选别名，部署平台若统一使用 Moonshot 命名可直接注入
# MOONSHOT_API_KEY=sk-your-kimi-api-key

# 可选 Secret 文件路径，适合 Docker / Kubernetes / PaaS Secret 挂载
# KIMI_API_KEY_FILE=/run/secrets/kimi_api_key
# MOONSHOT_API_KEY_FILE=/run/secrets/moonshot_api_key

# 可选 Secret 目录，程序会自动尝试读取如下文件名：
#   <AI_SECRETS_DIR>/kimi_api_key
#   <AI_SECRETS_DIR>/moonshot_api_key
# AI_SECRETS_DIR=/run/secrets

# ArkClaw 审核引擎 (可选)
ARKCLAW_API_KEY=
ARKCLAW_BASE_URL=https://api.arkclaw.com/v1
ARKCLAW_MODEL=arkclaw-chat

# --- 数据库 (一般不需要修改) ---
# DATABASE_URL=sqlite:///./app.db
