# ============================================
# Smart Doc Platform - 环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#
# 注意: .env 文件不会被 Git 追踪 (已在 .gitignore 中排除)
# ============================================

# --- AI 模型配置 ---
# 默认 AI 提供商: deepseek | qwen | arkclaw
DEFAULT_MODEL_PROVIDER=deepseek

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# 通义千问 / 阿里云 DashScope (https://dashscope.console.aliyun.com)
DASHSCOPE_API_KEY=
QWEN_MODEL=qwen-max

# ArkClaw 审核引擎 (可选)
ARKCLAW_API_KEY=
ARKCLAW_BASE_URL=https://api.arkclaw.com/v1
ARKCLAW_MODEL=arkclaw-chat

# --- 数据库 (一般不需要修改) ---
# DATABASE_URL=sqlite:///./app.db
