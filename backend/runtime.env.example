# Smart Doc Platform runtime overrides
# 首次在新电脑上运行后端前，复制本文件为 runtime.env 并填入真实值。

DEFAULT_MODEL_PROVIDER=kimi

# Kimi (Moonshot AI)
KIMI_API_KEY=sk-your-kimi-api-key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6

# Optional fallbacks
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
ARKCLAW_API_KEY=
ARKCLAW_BASE_URL=https://api.arkclaw.com/v1
ARKCLAW_MODEL=arkclaw-chat
